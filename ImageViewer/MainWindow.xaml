<Window x:Class="ImageViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ImageViewer"
        Title="ImageViewer"
        Width="1200" Height="800"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E" Foreground="#CCCCCC"
        AllowDrop="True" Drop="OnDrop">

    <Window.Resources>
        <local:ThumbnailConverter x:Key="ThumbConv"/>

        <ItemsPanelTemplate x:Key="ListPanel">
            <VirtualizingStackPanel/>
        </ItemsPanelTemplate>
        <ItemsPanelTemplate x:Key="GridPanel">
            <WrapPanel/>
        </ItemsPanelTemplate>

        <DataTemplate x:Key="ListItemTemplate">
            <TextBlock Text="{Binding RelativePath}" Margin="4,1"
                       TextTrimming="CharacterEllipsis"
                       ToolTip="{Binding RelativePath}"/>
        </DataTemplate>
        <DataTemplate x:Key="GridItemTemplate">
            <StackPanel Width="140" Margin="2" ToolTip="{Binding RelativePath}">
                <Border Width="130" Height="130" Background="#2A2A2A"
                        BorderBrush="#3E3E3E" BorderThickness="1">
                    <Image Source="{Binding FullPath, Converter={StaticResource ThumbConv}, IsAsync=True}"
                           Stretch="UniformToFill"
                           RenderOptions.BitmapScalingMode="LowQuality"/>
                </Border>
                <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis"
                           Foreground="#AAAAAA" FontSize="10" Margin="2,2,2,0"
                           HorizontalAlignment="Center" MaxWidth="130"/>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
            <DockPanel Margin="4,0">
                <Button Content="Open" Click="OnOpenClick" DockPanel.Dock="Left"
                        Padding="10,4" Margin="0,4" Background="#3E3E42" Foreground="#CCCCCC"
                        BorderBrush="#555555" Cursor="Hand"/>
                <Button x:Name="ViewModeButton" Content="Grid (G)" Click="OnToggleView"
                        DockPanel.Dock="Left" Padding="10,4" Margin="4,4,0,4"
                        Background="#3E3E42" Foreground="#CCCCCC"
                        BorderBrush="#555555" Cursor="Hand"/>
                <TextBlock x:Name="PathText" Text="フォルダを選択 (Ctrl+O / ドラッグ&amp;ドロップ)"
                           VerticalAlignment="Center" Margin="8,0" Foreground="#888888"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <!-- Main -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="100"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Folder tree + Tags -->
            <Grid Background="#252526">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="120" MinHeight="30"/>
                </Grid.RowDefinitions>

                <TreeView x:Name="FolderTree" Background="#252526" BorderThickness="0"
                          Foreground="#CCCCCC" Padding="2"
                          SelectedItemChanged="OnTreeSelected">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Name}" Margin="2,1" ToolTip="{Binding Path}"/>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>

                <GridSplitter Grid.Row="1" Height="4" Background="#3F3F46"
                              HorizontalAlignment="Stretch" ResizeDirection="Rows"/>

                <DockPanel Grid.Row="2">
                    <TextBlock DockPanel.Dock="Top" Text="Tags" Margin="8,4"
                               FontSize="11" Foreground="#666666"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <WrapPanel x:Name="TagPanel" Margin="4"/>
                    </ScrollViewer>
                </DockPanel>
            </Grid>

            <GridSplitter Grid.Column="1" Width="4" Background="#3F3F46"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

            <!-- Right pane -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="160" MinHeight="40"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="100"/>
                </Grid.RowDefinitions>

                <!-- Search -->
                <Border Background="#2D2D30" Padding="4">
                    <Grid>
                        <TextBox x:Name="SearchBox" Background="#3C3C3C" Foreground="#CCCCCC"
                                 CaretBrush="#CCCCCC" BorderBrush="#555555"
                                 Padding="6,3" FontSize="12"
                                 TextChanged="OnSearchChanged"/>
                        <TextBlock x:Name="SearchPlaceholder" Text="検索... (Ctrl+F)"
                                   IsHitTestVisible="False" Foreground="#666666"
                                   Margin="10,6" FontSize="12"/>
                    </Grid>
                </Border>

                <!-- Image list -->
                <ListBox Grid.Row="1" x:Name="ImageList" Background="#1E1E1E" BorderThickness="0"
                         Foreground="#CCCCCC" FontSize="12" FontFamily="Consolas"
                         SelectionMode="Extended"
                         SelectionChanged="OnImageSelected"
                         ItemTemplate="{StaticResource ListItemTemplate}"
                         ItemsPanel="{StaticResource ListPanel}"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ContextMenu>
                        <ContextMenu x:Name="ImageContextMenu" Opened="OnContextMenuOpened">
                            <MenuItem Header="タグ追加 (T)" Click="OnAddTagClick"/>
                            <Separator x:Name="TagMenuSeparator"/>
                            <MenuItem Header="エクスプローラーで開く" Click="OnOpenInExplorer"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                </ListBox>

                <GridSplitter Grid.Row="2" Height="4" Background="#3F3F46"
                              HorizontalAlignment="Stretch" VerticalAlignment="Center"
                              ResizeDirection="Rows"/>

                <!-- Preview -->
                <Grid Grid.Row="3" x:Name="PreviewArea">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <WrapPanel Margin="8,4" Background="#1E1E1E">
                        <TextBlock x:Name="CountText" Foreground="#888888" FontSize="12"/>
                        <TextBlock x:Name="DimText" Foreground="#666666" FontSize="12" Margin="12,0,0,0"/>
                        <TextBlock x:Name="ZoomText" Foreground="#666666" FontSize="12" Margin="12,0,0,0"/>
                        <TextBlock x:Name="FileNameText" Foreground="#666666" FontSize="12" Margin="12,0,0,0"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="AssetTagsText" Foreground="#5A9FD4" FontSize="12" Margin="12,0,0,0"/>
                    </WrapPanel>

                    <Border Grid.Row="1" x:Name="PreviewBorder" Background="#181818"
                            ClipToBounds="True"
                            MouseWheel="OnPreviewMouseWheel"
                            MouseLeftButtonDown="OnPreviewMouseDown"
                            MouseMove="OnPreviewMouseMove"
                            MouseLeftButtonUp="OnPreviewMouseUp">
                        <Image x:Name="PreviewImage" Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="Fant"
                               RenderTransformOrigin="0.5,0.5">
                            <Image.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="PreviewScale"/>
                                    <TranslateTransform x:Name="PreviewTranslate"/>
                                </TransformGroup>
                            </Image.RenderTransform>
                        </Image>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#007ACC" Padding="6,2">
            <DockPanel>
                <TextBlock x:Name="StatusText" Foreground="White" FontSize="11"/>
                <TextBlock x:Name="StatusRight" Foreground="White" FontSize="11"
                           HorizontalAlignment="Right" DockPanel.Dock="Right"/>
            </DockPanel>
        </Border>

        <!-- Keyboard shortcut help overlay -->
        <Border x:Name="HelpOverlay" Grid.RowSpan="3"
                Background="#DD1E1E1E" Visibility="Collapsed"
                MouseDown="OnHelpOverlayClick">
            <Border Background="#282828" BorderBrush="#555555" BorderThickness="1"
                    CornerRadius="8" Padding="28,24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MaxWidth="420">
                <StackPanel>
                    <TextBlock Text="Keyboard Shortcuts" FontSize="16" FontWeight="SemiBold"
                               Foreground="#EEEEEE" Margin="0,0,0,14"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                            <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                            <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                            <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                            <RowDefinition/><RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"  Grid.Column="0" Text="J / K,  Up / Down" Foreground="#E0A050" FontFamily="Consolas" Margin="0,2"/>
                        <TextBlock Grid.Row="0"  Grid.Column="1" Text="前 / 次の画像" Foreground="#CCCCCC" Margin="0,2"/>
                        <TextBlock Grid.Row="1"  Grid.Column="0" Text="Space / Back" Foreground="#E0A050" FontFamily="Consolas" Margin="0,2"/>
                        <TextBlock Grid.Row="1"  Grid.Column="1" Text="前 / 次の画像" Foreground="#CCCCCC" Margin="0,2"/>
                        <TextBlock Grid.Row="2"  Grid.Column="0" Text="PageUp / Down" Foreground="#E0A050" FontFamily="Consolas" Margin="0,2"/>
                        <TextBlock Grid.Row="2"  Grid.Column="1" Text="10件送り (Grid: 20件)" Foreground="#CCCCCC" Margin="0,2"/>
                        <TextBlock Grid.Row="3"  Grid.Column="0" Text="Home / End" Foreground="#E0A050" FontFamily="Consolas" Margin="0,2"/>
                        <TextBlock Grid.Row="3"  Grid.Column="1" Text="先頭 / 末尾" Foreground="#CCCCCC" Margin="0,2"/>
                        <TextBlock Grid.Row="4"  Grid.Column="0" Text="T" Foreground="#E0A050" FontFamily="Consolas" Margin="0,2"/>
                        <TextBlock Grid.Row="4"  Grid.Column="1" Text="タグ追加" Foreground="#CCCCCC" Margin="0,2"/>
                        <TextBlock Grid.Row="5"  Grid.Column="0" Text="G" Foreground="#E0A050" FontFamily="Consolas" Margin="0,2"/>
                        <TextBlock Grid.Row="5"  Grid.Column="1" Text="グリッド / リスト切替" Foreground="#CCCCCC" Margin="0,2"/>
                        <TextBlock Grid.Row="6"  Grid.Column="0" Text="Ctrl+F" Foreground="#E0A050" FontFamily="Consolas" Margin="0,2"/>
                        <TextBlock Grid.Row="6"  Grid.Column="1" Text="検索" Foreground="#CCCCCC" Margin="0,2"/>
                        <TextBlock Grid.Row="7"  Grid.Column="0" Text="Ctrl+O" Foreground="#E0A050" FontFamily="Consolas" Margin="0,2"/>
                        <TextBlock Grid.Row="7"  Grid.Column="1" Text="フォルダを開く" Foreground="#CCCCCC" Margin="0,2"/>
                        <TextBlock Grid.Row="8"  Grid.Column="0" Text="Ctrl+A" Foreground="#E0A050" FontFamily="Consolas" Margin="0,2"/>
                        <TextBlock Grid.Row="8"  Grid.Column="1" Text="全選択" Foreground="#CCCCCC" Margin="0,2"/>
                        <TextBlock Grid.Row="9"  Grid.Column="0" Text="Ctrl+D" Foreground="#E0A050" FontFamily="Consolas" Margin="0,2"/>
                        <TextBlock Grid.Row="9"  Grid.Column="1" Text="重複ファイル検出" Foreground="#CCCCCC" Margin="0,2"/>
                        <TextBlock Grid.Row="10"  Grid.Column="0" Text="Enter" Foreground="#E0A050" FontFamily="Consolas" Margin="0,2"/>
                        <TextBlock Grid.Row="10"  Grid.Column="1" Text="外部ビューアで開く" Foreground="#CCCCCC" Margin="0,2"/>
                        <TextBlock Grid.Row="11" Grid.Column="0" Text="Tab" Foreground="#E0A050" FontFamily="Consolas" Margin="0,2"/>
                        <TextBlock Grid.Row="11" Grid.Column="1" Text="ツリーにフォーカス" Foreground="#CCCCCC" Margin="0,2"/>
                        <TextBlock Grid.Row="12" Grid.Column="0" Text="Escape" Foreground="#E0A050" FontFamily="Consolas" Margin="0,2"/>
                        <TextBlock Grid.Row="12" Grid.Column="1" Text="フィルタクリア" Foreground="#CCCCCC" Margin="0,2"/>
                        <TextBlock Grid.Row="13" Grid.Column="0" Text="Right-click" Foreground="#E0A050" FontFamily="Consolas" Margin="0,2"/>
                        <TextBlock Grid.Row="13" Grid.Column="1" Text="タグ削除 / エクスプローラー" Foreground="#CCCCCC" Margin="0,2"/>
                        <TextBlock Grid.Row="14" Grid.Column="0" Text="Wheel / +/-" Foreground="#E0A050" FontFamily="Consolas" Margin="0,2"/>
                        <TextBlock Grid.Row="14" Grid.Column="1" Text="ズーム / ドラッグでパン" Foreground="#CCCCCC" Margin="0,2"/>
                        <TextBlock Grid.Row="15" Grid.Column="0" Text="F / Double-click" Foreground="#E0A050" FontFamily="Consolas" Margin="0,2"/>
                        <TextBlock Grid.Row="15" Grid.Column="1" Text="フィットに戻す" Foreground="#CCCCCC" Margin="0,2"/>
                        <TextBlock Grid.Row="16" Grid.Column="0" Text="B" Foreground="#E0A050" FontFamily="Consolas" Margin="0,2"/>
                        <TextBlock Grid.Row="16" Grid.Column="1" Text="背景切替 (暗/チェッカー/白/灰)" Foreground="#CCCCCC" Margin="0,2"/>
                        <TextBlock Grid.Row="17" Grid.Column="0" Text="?" Foreground="#E0A050" FontFamily="Consolas" Margin="0,6,0,0"/>
                        <TextBlock Grid.Row="17" Grid.Column="1" Text="このヘルプを表示" Foreground="#CCCCCC" Margin="0,6,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
