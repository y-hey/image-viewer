<Window x:Class="ImageViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ImageViewer"
        Width="1200" Height="800"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E" Foreground="#CCCCCC"
        AllowDrop="True" Drop="OnDrop">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
            <DockPanel Margin="4,0">
                <Button Content="Open" Click="OnOpenClick" DockPanel.Dock="Left"
                        Padding="10,4" Margin="0,4" Background="#3E3E42" Foreground="#CCCCCC"
                        BorderBrush="#555555" Cursor="Hand"/>
                <TextBlock x:Name="PathText" Text="フォルダを選択 (Ctrl+O / ドラッグ&amp;ドロップ)"
                           VerticalAlignment="Center" Margin="8,0" Foreground="#888888"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <!-- Main -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="100"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Folder tree -->
            <TreeView x:Name="FolderTree" Background="#252526" BorderThickness="0"
                      Foreground="#CCCCCC" Padding="2"
                      SelectedItemChanged="OnTreeSelected">
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                        <TextBlock Text="{Binding Name}" Margin="2,1"
                                   ToolTip="{Binding Path}"/>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

            <GridSplitter Grid.Column="1" Width="4" Background="#3F3F46"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

            <!-- Right pane -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="160" MinHeight="40"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="100"/>
                </Grid.RowDefinitions>

                <!-- Image list -->
                <ListBox x:Name="ImageList" Background="#1E1E1E" BorderThickness="0"
                         Foreground="#CCCCCC" FontSize="12" FontFamily="Consolas"
                         SelectionChanged="OnImageSelected"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding RelativePath}" Margin="4,1"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding RelativePath}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <GridSplitter Grid.Row="1" Height="4" Background="#3F3F46"
                              HorizontalAlignment="Stretch" VerticalAlignment="Center"
                              ResizeDirection="Rows"/>

                <!-- Preview -->
                <Grid Grid.Row="2" x:Name="PreviewArea" Background="#181818">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="8,4">
                        <TextBlock x:Name="CountText" Foreground="#888888" FontSize="12"/>
                        <TextBlock x:Name="DimText" Foreground="#666666" FontSize="12" Margin="12,0,0,0"/>
                        <TextBlock x:Name="FileNameText" Foreground="#666666" FontSize="12" Margin="12,0,0,0"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <Image Grid.Row="1" x:Name="PreviewImage" Stretch="Uniform" Margin="4"
                           RenderOptions.BitmapScalingMode="Fant"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
